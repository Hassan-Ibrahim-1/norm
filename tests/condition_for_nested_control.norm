// test: "loop control statements: condition-only loop nested cleanup"
// expect:
// 10
// 31
// 73
// 124
// 120
// 238
// 5

{
    mut i := 0;
    mut total := 0;
    mut seen := 0;

    for i < 6 {
        base := i + 1;
        {
            inner := base * 10;
            if i == 2 {
                skipped := inner + 1000;
                i += 1;
                continue;
            }
            if i == 5 {
                stopped := inner + 2000;
                break;
            }
            total += inner;
        }

        after := total + i;
        seen += after;
        print(after);
        i += 1;
    }

    print(total);
    print(seen);
    print(i);
}
